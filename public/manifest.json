{
  "manifest_version": 3,
  "name": "GitHub HTML Preview",
  "version": "0.1.0",
  "description": "Adds a Preview button next to Code/Blame on GitHub blob pages to render HTML files inline.",
  "browser_specific_settings": {
    "gecko": {
      "id": "github-html-preview@inkyupark",
      "strict_min_version": "115.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "icons": {
    "48": "icons/icon.svg",
    "96": "icons/icon.svg"
  },
  "content_scripts": [
    {
      "matches": ["*://github.com/*/blob/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "host_permissions": [
    "*://github.com/*",
    "*://raw.githubusercontent.com/*"
  ]
}
